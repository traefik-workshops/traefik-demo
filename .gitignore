.terraform*
*.tfstate
*.tfstate.backup
*.tfplan
crash.log
crash.*.log

.DS_Store

.history
.idea/
.vscode/

**/bin
**/images

runtime-config.yaml

# Local Claude Code settings — per-user, never committed
.claude/settings.local.json


# Helm
# - Chart.lock: COMMITTED (pin subchart digests for reproducible packaging)
# - charts/*.tgz: NOT committed (regenerated by `helm dep update` from Chart.lock)
helm/*/charts/*.tgz
helm/*/charts/*/

# Helm-docs scratch
*.md.bak

# ============================================================================
# Secrets — NEVER commit. .example variants are allowed (carve-outs below).
# Defense-in-depth: gitleaks pre-commit hook catches anything that slips past.
# ============================================================================

# Terraform variable files (often contain real values)
*.tfvars
*.tfvars.json
*.auto.tfvars
!*.tfvars.example
!*.tfvars.json.example

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Kubeconfig — match the file kubeconfig OR <something>.kubeconfig, but NOT
# kubeconfig.tf (legitimate Terraform file defining kubeconfig outputs).
/kubeconfig
**/kubeconfig
**/kubeconfig.yaml
**/kubeconfig.yml
*.kubeconfig

# Certificates and private keys
*.pem
*.key
*.p12
*.pfx
*.p8
*.crt
*.cer

# Cloud provider credentials
credentials
credentials.json
*-credentials.json
service-account*.json
gcp-key*.json
aws-credentials
.aws/credentials

# Files explicitly named "secret" (Helm Secret templates are in templates/ dirs
# and are matched by their full path, not just basename, so don't conflict)
/secrets.yaml
/secrets.yml
/secret.yaml
/secret.yml
*-secrets-real.yaml

# Sealed-secrets / sops / age key material (if ever introduced)
*.enc.yaml
*.sops.yaml
*.age

# Anything dropped into a top-level secrets/ scratch dir
/secrets/
