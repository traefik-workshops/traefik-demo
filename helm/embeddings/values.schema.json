{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "embeddings chart values",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "default": "michaelfeil/infinity"
        },
        "tag": {
          "type": "string",
          "default": "0.0.75"
        },
        "pullPolicy": {
          "type": "string",
          "default": "IfNotPresent"
        }
      }
    },
    "model": {
      "type": "string",
      "default": "nomic-embed-text"
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "default": "ClusterIP"
        },
        "port": {
          "type": "integer",
          "default": 7997
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "limits": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "500m"
            },
            "memory": {
              "type": "string",
              "default": "1Gi"
            }
          }
        },
        "requests": {
          "type": "object",
          "properties": {
            "cpu": {
              "type": "string",
              "default": "100m"
            },
            "memory": {
              "type": "string",
              "default": "256Mi"
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
